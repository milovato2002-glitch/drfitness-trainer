/* ══ CALORIE CALCULATOR ══ */
function calcCalories(){
  const sex=document.getElementById('c-sex').value;
  const age=parseFloat(document.getElementById('c-age').value);
  const heightIn=parseFloat(document.getElementById('c-height').value);
  const weightLbs=parseFloat(document.getElementById('c-weight').value);
  const activity=parseFloat(document.getElementById('c-activity').value);
  const goal=document.getElementById('c-goal').value;
  if([age,heightIn,weightLbs].some(v=>isNaN(v)||v<=0)){alert('Please fill in all fields.');return;}
  const kg=weightLbs*0.453592;
  const cm=heightIn*2.54;
  let rmr=sex==='m'?(10*kg)+(6.25*cm)-(5*age)+5:(10*kg)+(6.25*cm)-(5*age)-161;
  const tdee=rmr*activity;
  const goalMap={loss:{adj:-400,label:'Fat Loss',prot:2.0,carb:3.5,fat:1.0,note:'Moderate deficit of ~400 kcal. Higher protein preserves muscle during fat loss. Increase deficit slowly and monitor performance.'},maintain:{adj:0,label:'Maintenance / Recomp',prot:1.8,carb:5.0,fat:1.2,note:'At TDEE. Body recomposition is possible here — prioritize training quality and protein distribution.'},gain:{adj:300,label:'Muscle Gain',prot:2.0,carb:6.0,fat:1.3,note:'Modest surplus of ~300 kcal minimizes fat gain. Increase by 50–100 kcal every 2 weeks if not gaining at desired rate.'},glp1:{adj:-300,label:'GLP-1/AOM Client',prot:2.2,carb:3.0,fat:0.9,note:'⚠️ GLP-1 clients often eat far below calculated targets due to appetite suppression. Prioritize protein above all — protein shakes are frequently necessary. Refer to RD for individualized planning. Monitor closely.'}};
  const g=goalMap[goal];
  const targetCals=Math.round(tdee+g.adj);
  const protG=Math.round(kg*g.prot);
  const fatG=Math.round(kg*g.fat);
  const protCals=protG*4;const fatCals=fatG*9;
  const carbCals=Math.max(0,targetCals-protCals-fatCals);
  const carbG=Math.round(carbCals/4);
  document.getElementById('calcResults').classList.add('show');
  document.getElementById('resultCards').innerHTML=`
    <div class="result-card"><div class="rc-val">${Math.round(rmr)}</div><div class="rc-unit">kcal</div><div class="rc-label">RMR (Mifflin-St Jeor)</div></div>
    <div class="result-card"><div class="rc-val">${Math.round(tdee)}</div><div class="rc-unit">kcal</div><div class="rc-label">TDEE (Maintenance)</div></div>
    <div class="result-card"><div class="rc-val">${targetCals}</div><div class="rc-unit">kcal</div><div class="rc-label">Target (${g.label})</div></div>
    <div class="result-card"><div class="rc-val">${Math.round(kg)}</div><div class="rc-unit">kg</div><div class="rc-label">Body Weight</div></div>`;
  document.getElementById('macroLabel').textContent='Daily Macros — '+g.label;
  document.getElementById('macroRow').innerHTML=`
    <div class="macro-card mc-p"><div class="mv">${protG}g</div><div class="ml">Protein (${Math.round(g.prot*10)/10}g/kg) · ${protCals} kcal</div></div>
    <div class="macro-card mc-c"><div class="mv">${carbG}g</div><div class="ml">Carbohydrate · ${carbCals} kcal</div></div>
    <div class="macro-card mc-f"><div class="mv">${fatG}g</div><div class="ml">Fat (${Math.round(g.fat*10)/10}g/kg) · ${fatCals} kcal</div></div>`;
  document.getElementById('calcNotes').innerHTML=`<strong>Notes:</strong> ${g.note}<br><br><em>These are estimates based on averages. Individual variance is ±10–15%. Calorie and macro recommendations are for educational purposes only. Refer to a Registered Dietitian for clinical nutrition planning.</em>`;
}
</script>
</body>
