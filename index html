<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Dr. Fitness — Trainer Reference</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;500;600&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --navy:#0a1628;--navy2:#0e1e36;--navy3:#142444;--blue2:#1e4a8a;
  --gold:#f0a500;--gold2:#ffb820;--gold-dim:rgba(240,165,0,0.12);--gold-dim2:rgba(240,165,0,0.06);
  --red:#e63946;--red-dim:rgba(230,57,70,0.15);--green:#2dc653;--green-dim:rgba(45,198,83,0.12);
  --amber:#f4a261;--teal:#2dd4bf;
  --text:#e8edf5;--text2:#8fa3c0;--text3:#4a6080;
  --border:rgba(240,165,0,0.18);--border2:rgba(255,255,255,0.07);
  --radius:10px;--radius-sm:6px;
}
html{font-size:16px;}
body{background:var(--navy);color:var(--text);font-family:'Barlow',sans-serif;font-weight:300;min-height:100vh;display:flex;flex-direction:column;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(-55deg,rgba(255,255,255,0.015) 0px,rgba(255,255,255,0.015) 1px,transparent 1px,transparent 28px);pointer-events:none;z-index:0;}

/* SPLASH */
#splash{position:fixed;inset:0;background:var(--navy);z-index:1000;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;}
.splash-logo{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;letter-spacing:0.04em;color:var(--gold);line-height:1;margin-bottom:0.2rem;}
.splash-sub{font-family:'Barlow Condensed',sans-serif;font-size:0.85rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--text2);margin-bottom:2.5rem;}
.splash-disc{background:rgba(230,57,70,0.1);border:1px solid rgba(230,57,70,0.3);border-radius:var(--radius);padding:1.25rem 1.5rem;max-width:480px;margin-bottom:2rem;text-align:left;}
.splash-disc h3{font-family:'Barlow Condensed',sans-serif;font-size:0.72rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--red);margin-bottom:0.6rem;display:flex;align-items:center;gap:6px;}
.splash-disc p{font-size:0.82rem;color:var(--text2);line-height:1.65;}
.splash-disc strong{color:var(--text);font-weight:500;}
.splash-enter{background:var(--gold);color:var(--navy);border:none;padding:14px 40px;border-radius:var(--radius);font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;transition:all 0.15s;}
.splash-enter:hover{background:var(--gold2);transform:translateY(-1px);}

/* HEADER */
header{position:sticky;top:0;z-index:100;background:rgba(10,22,40,0.96);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0.7rem 1.25rem;}
.hdr-logo{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:0.05em;color:var(--gold);line-height:1;}
.hdr-tagline{font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--text3);}
.hdr-right{display:flex;align-items:center;gap:6px;}
.cert-badge{padding:3px 8px;border-radius:4px;font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;border:1px solid;}
.cert-nasm{background:rgba(30,74,138,0.25);border-color:rgba(30,74,138,0.5);color:#60a5fa;}
.cert-ace{background:rgba(45,198,83,0.1);border-color:rgba(45,198,83,0.35);color:#2dc653;}
.cert-issa{background:rgba(240,165,0,0.1);border-color:rgba(240,165,0,0.35);color:var(--gold);}
.cert-epi{background:rgba(230,57,70,0.1);border-color:rgba(230,57,70,0.35);color:var(--red);}

/* NAV */
.nav-tabs{display:flex;overflow-x:auto;scrollbar-width:none;background:var(--navy2);border-bottom:1px solid var(--border2);padding:0 0.5rem;position:sticky;top:57px;z-index:90;}
.nav-tabs::-webkit-scrollbar{display:none;}
.nav-tab{white-space:nowrap;padding:0.75rem 1rem;border:none;background:transparent;color:var(--text3);font-family:'Barlow Condensed',sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.15s;flex-shrink:0;}
.nav-tab:hover{color:var(--text);}
.nav-tab.active{color:var(--gold);border-bottom-color:var(--gold);}

main{position:relative;z-index:10;flex:1;display:flex;flex-direction:column;}
.panel{display:none;flex:1;flex-direction:column;}
.panel.active{display:flex;}

/* CHAT */
.chat-layout{display:flex;flex:1;overflow:hidden;height:calc(100vh - 115px);}
.qa-sidebar{width:210px;flex-shrink:0;border-right:1px solid var(--border2);overflow-y:auto;padding:0.6rem;display:flex;flex-direction:column;gap:4px;scrollbar-width:thin;scrollbar-color:var(--border2) transparent;}
.qa-section{font-family:'Barlow Condensed',sans-serif;font-size:0.62rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--text3);padding:0.5rem 0.25rem 0.15rem;margin-top:4px;}
.qa-btn{width:100%;padding:7px 9px;border-radius:var(--radius-sm);border:1px solid var(--border2);background:transparent;color:var(--text2);font-family:'Barlow',sans-serif;font-size:0.76rem;font-weight:400;text-align:left;cursor:pointer;transition:all 0.12s;line-height:1.3;}
.qa-btn:hover{background:var(--gold-dim);border-color:var(--border);color:var(--text);}
.qa-btn.inj{border-left:2px solid var(--red);}
.qa-btn.nut{border-left:2px solid var(--green);}
.qa-btn.wrk{border-left:2px solid var(--gold);}
.qa-btn.wrm{border-left:2px solid #60a5fa;}
.qa-btn.spc{border-left:2px solid var(--amber);}
.qa-btn.oli{border-left:2px solid var(--teal);}
.qa-btn.rec{border-left:2px solid #a78bfa;}

.chat-main{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.messages{flex:1;overflow-y:auto;padding:1.25rem 1.5rem;display:flex;flex-direction:column;gap:1.25rem;scrollbar-width:thin;scrollbar-color:var(--border2) transparent;}
.msg{display:flex;gap:10px;max-width:100%;}
.msg.user{flex-direction:row-reverse;}
.msg-avatar{width:30px;height:30px;border-radius:var(--radius-sm);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Barlow Condensed',sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:0.04em;}
.msg.user .msg-avatar{background:var(--gold);color:var(--navy);}
.msg.ai .msg-avatar{background:var(--navy3);border:1px solid var(--border);}
.msg-body{flex:1;min-width:0;}
.msg-label{font-family:'Barlow Condensed',sans-serif;font-size:0.66rem;letter-spacing:0.09em;text-transform:uppercase;color:var(--text3);margin-bottom:5px;}
.msg.user .msg-label{text-align:right;}
.msg-bubble{padding:0.875rem 1.1rem;border-radius:var(--radius);font-size:0.875rem;line-height:1.75;font-weight:300;}
.msg.user .msg-bubble{background:var(--blue2);border:1px solid rgba(30,74,138,0.5);color:var(--text);border-radius:var(--radius) var(--radius) 4px var(--radius);}
.msg.ai .msg-bubble{background:var(--navy2);border:1px solid var(--border2);color:var(--text);border-radius:var(--radius) var(--radius) var(--radius) 4px;}
.msg-bubble strong{font-weight:600;color:var(--gold);}
.msg-bubble h3{font-family:'Barlow Condensed',sans-serif;font-size:0.9rem;font-weight:700;letter-spacing:0.05em;color:var(--text);margin:0.9rem 0 0.3rem;text-transform:uppercase;}
.msg-bubble h3:first-child{margin-top:0;}
.msg-bubble ul,.msg-bubble ol{margin:0.4rem 0 0.4rem 1.1rem;display:flex;flex-direction:column;gap:3px;}
.msg-bubble li{color:var(--text2);font-size:0.85rem;}
.msg-bubble p{margin-bottom:0.45rem;}
.msg-bubble p:last-child{margin-bottom:0;}
.disc-box{margin-top:0.75rem;padding:0.6rem 0.875rem;background:var(--red-dim);border:1px solid rgba(230,57,70,0.25);border-radius:var(--radius-sm);font-size:0.78rem;color:rgba(230,57,70,0.9);line-height:1.5;display:flex;align-items:flex-start;gap:6px;}

.typing{display:flex;align-items:center;gap:4px;padding:0.75rem 1rem;background:var(--navy2);border:1px solid var(--border2);border-radius:var(--radius);width:fit-content;}
.typing span{width:6px;height:6px;border-radius:50%;background:var(--gold);animation:tdot 1.2s infinite;}
.typing span:nth-child(2){animation-delay:0.2s;}
.typing span:nth-child(3){animation-delay:0.4s;}
@keyframes tdot{0%,60%,100%{transform:translateY(0);opacity:0.3;}30%{transform:translateY(-5px);opacity:1;}}

.input-area{padding:0.875rem 1.5rem 1rem;border-top:1px solid var(--border2);background:rgba(10,22,40,0.92);}
.mode-row{display:flex;gap:5px;margin-bottom:8px;flex-wrap:wrap;}
.mode-chip{padding:3px 10px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text3);font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:all 0.12s;}
.mode-chip:hover,.mode-chip.active{border-color:var(--gold);color:var(--gold);background:var(--gold-dim2);}
.input-row{display:flex;gap:8px;align-items:flex-end;background:var(--navy2);border:1px solid var(--border2);border-radius:var(--radius);padding:9px 9px 9px 14px;transition:border-color 0.15s;}
.input-row:focus-within{border-color:var(--border);}
#qi{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:'Barlow',sans-serif;font-size:0.9rem;font-weight:300;resize:none;max-height:120px;min-height:22px;line-height:1.5;}
#qi::placeholder{color:var(--text3);}
.send-btn{width:34px;height:34px;border-radius:var(--radius-sm);background:var(--gold);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;}
.send-btn:hover{background:var(--gold2);}
.send-btn:disabled{opacity:0.3;cursor:not-allowed;}
.input-hint{margin-top:5px;font-size:0.67rem;color:var(--text3);text-align:center;}

.welcome{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;}
.welcome-logo{font-family:'Bebas Neue',sans-serif;font-size:3.5rem;letter-spacing:0.06em;color:var(--gold);line-height:1;margin-bottom:0.15rem;}
.welcome-sub{font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text3);margin-bottom:1.75rem;}
.welcome-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;width:100%;max-width:660px;}
.w-card{background:var(--navy2);border:1px solid var(--border2);border-radius:var(--radius);padding:0.9rem;cursor:pointer;text-align:left;transition:all 0.15s;position:relative;overflow:hidden;}
.w-card::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--gold);opacity:0;transition:opacity 0.15s;}
.w-card:hover{border-color:var(--border);background:var(--navy3);}
.w-card:hover::after{opacity:1;}
.w-card-icon{font-size:1.3rem;margin-bottom:5px;}
.w-card-title{font-family:'Barlow Condensed',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:3px;text-transform:uppercase;letter-spacing:0.05em;}
.w-card-text{font-size:0.74rem;color:var(--text2);line-height:1.45;}

/* REF PANELS */
.ref-panel{padding:1.5rem;overflow-y:auto;display:flex;flex-direction:column;gap:1.2rem;}
.ref-header{border-bottom:1px solid var(--border2);padding-bottom:1rem;}
.ref-header h2{font-family:'Bebas Neue',sans-serif;font-size:2rem;letter-spacing:0.05em;color:var(--gold);margin-bottom:0.2rem;}
.ref-header p{font-size:0.83rem;color:var(--text2);line-height:1.6;margin-top:0.25rem;}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:12px;}
.ref-card{background:var(--navy2);border:1px solid var(--border2);border-radius:var(--radius);padding:1rem 1.2rem;}
.ref-card:hover{border-color:var(--border);}
.ref-card-label{font-family:'Barlow Condensed',sans-serif;font-size:0.65rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--text3);margin-bottom:0.3rem;}
.ref-card h3{font-family:'Barlow Condensed',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:0.5rem;}
.ref-card p,.ref-card li{font-size:0.81rem;color:var(--text2);line-height:1.6;}
.ref-card ul{margin-left:1rem;display:flex;flex-direction:column;gap:2px;}
.ref-card strong{color:var(--gold);font-weight:600;}
.ref-card em{color:var(--text3);font-style:normal;font-size:0.77rem;}
.tag{display:inline-block;padding:2px 7px;border-radius:4px;font-size:0.66rem;font-weight:700;letter-spacing:0.05em;font-family:'Barlow Condensed',sans-serif;margin-right:4px;margin-bottom:5px;}
.tag-r{background:var(--red-dim);color:var(--red);border:1px solid rgba(230,57,70,0.3);}
.tag-g{background:var(--green-dim);color:var(--green);border:1px solid rgba(45,198,83,0.3);}
.tag-b{background:rgba(96,165,250,0.1);color:#60a5fa;border:1px solid rgba(96,165,250,0.3);}
.tag-t{background:rgba(45,212,191,0.1);color:var(--teal);border:1px solid rgba(45,212,191,0.3);}

.phase-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px;}
.phase-card{background:var(--navy3);border:1px solid var(--border2);border-radius:var(--radius);padding:0.875rem 1rem;border-top:3px solid var(--gold);}
.phase-num{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--gold);opacity:0.25;line-height:1;}
.phase-name{font-family:'Barlow Condensed',sans-serif;font-size:0.95rem;font-weight:700;color:var(--text);margin-bottom:6px;}
.phase-detail{font-size:0.77rem;color:var(--text2);line-height:1.55;}
.phase-detail strong{color:var(--gold);font-weight:600;}

.accord{background:var(--navy2);border:1px solid var(--border2);border-radius:var(--radius);overflow:hidden;}
.accord-hdr{width:100%;padding:0.875rem 1.1rem;display:flex;align-items:center;justify-content:space-between;background:transparent;border:none;cursor:pointer;color:var(--text);font-family:'Barlow Condensed',sans-serif;font-size:0.92rem;font-weight:700;letter-spacing:0.05em;text-align:left;text-transform:uppercase;transition:background 0.12s;}
.accord-hdr:hover{background:var(--gold-dim2);}
.accord-hdr svg{flex-shrink:0;transition:transform 0.2s;color:var(--gold);}
.accord-hdr.open svg{transform:rotate(180deg);}
.accord-body{display:none;padding:0.25rem 1.1rem 1rem;font-size:0.82rem;color:var(--text2);line-height:1.7;}
.accord-body.open{display:block;}
.accord-body ul{margin-left:1rem;display:flex;flex-direction:column;gap:4px;margin-top:4px;}
.accord-body strong{color:var(--gold);font-weight:600;}
.sub-lbl{font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);margin:0.8rem 0 0.25rem;display:block;}

.alert-box{background:var(--red-dim);border:1px solid rgba(230,57,70,0.25);border-radius:var(--radius);padding:0.875rem 1.1rem;font-size:0.82rem;color:rgba(230,57,70,0.9);line-height:1.6;display:flex;gap:8px;}

/* CALORIE CALCULATOR */
.calc-wrap{background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);padding:1.5rem;}
.calc-wrap h3{font-family:'Barlow Condensed',sans-serif;font-size:1.1rem;font-weight:700;color:var(--text);margin-bottom:1rem;letter-spacing:0.05em;text-transform:uppercase;}
.calc-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;margin-bottom:1rem;}
.calc-field label{display:block;font-family:'Barlow Condensed',sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--text3);margin-bottom:5px;}
.calc-field input,.calc-field select{width:100%;padding:9px 12px;background:var(--navy3);border:1px solid var(--border2);border-radius:var(--radius-sm);color:var(--text);font-family:'Barlow',sans-serif;font-size:0.875rem;font-weight:300;outline:none;transition:border-color 0.15s;}
.calc-field input:focus,.calc-field select:focus{border-color:var(--border);}
.calc-field select option{background:var(--navy3);}
.calc-btn{padding:10px 24px;background:var(--gold);border:none;border-radius:var(--radius-sm);color:var(--navy);font-family:'Barlow Condensed',sans-serif;font-size:0.875rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;transition:all 0.15s;}
.calc-btn:hover{background:var(--gold2);}
.calc-results{display:none;margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid var(--border2);}
.calc-results.show{display:block;}
.calc-results h4{font-family:'Barlow Condensed',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--text3);margin-bottom:0.75rem;}
.result-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;margin-bottom:1rem;}
.result-card{background:var(--navy3);border:1px solid var(--border2);border-radius:var(--radius-sm);padding:0.875rem;text-align:center;}
.result-card .rc-val{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;color:var(--gold);line-height:1;}
.result-card .rc-unit{font-size:0.7rem;color:var(--text3);font-family:'Barlow Condensed',sans-serif;letter-spacing:0.08em;}
.result-card .rc-label{font-size:0.78rem;color:var(--text2);margin-top:4px;}
.macro-row{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:1rem;}
.macro-card{background:var(--navy3);border-radius:var(--radius-sm);padding:0.75rem;text-align:center;border:1px solid var(--border2);}
.macro-card .mv{font-family:'Bebas Neue',sans-serif;font-size:1.4rem;line-height:1;}
.macro-card .ml{font-size:0.72rem;color:var(--text2);margin-top:2px;}
.mc-p{color:#60a5fa;border-top:2px solid #60a5fa;}
.mc-c{color:var(--amber);border-top:2px solid var(--amber);}
.mc-f{color:var(--green);border-top:2px solid var(--green);}
.goal-tabs{display:flex;gap:6px;margin-bottom:0.75rem;flex-wrap:wrap;}
.goal-tab{padding:4px 12px;border-radius:20px;border:1px solid var(--border2);background:transparent;color:var(--text3);font-family:'Barlow Condensed',sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;cursor:pointer;transition:all 0.12s;}
.goal-tab.active{border-color:var(--gold);color:var(--gold);background:var(--gold-dim2);}
.calc-note{font-size:0.77rem;color:var(--text3);line-height:1.6;margin-top:0.5rem;}

/* OPT DRILL TABLE */
.drill-table{width:100%;border-collapse:collapse;font-size:0.8rem;}
.drill-table th{background:var(--navy3);color:var(--text3);font-family:'Barlow Condensed',sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:8px 12px;text-align:left;border-bottom:1px solid var(--border2);}
.drill-table td{padding:8px 12px;border-bottom:1px solid rgba(255,255,255,0.04);color:var(--text2);vertical-align:top;}
.drill-table tr:last-child td{border-bottom:none;}
.drill-table tr:hover td{background:rgba(255,255,255,0.02);}
.drill-table strong{color:var(--gold);font-weight:600;}
.drill-phase-hdr{background:rgba(240,165,0,0.08);color:var(--gold)!important;font-family:'Barlow Condensed',sans-serif!important;font-weight:700!important;letter-spacing:0.05em!important;}

/* SCROLLBAR */
::-webkit-scrollbar{width:4px;height:4px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px;}
.hidden{display:none!important;}

@media(max-width:680px){
  .qa-sidebar{display:none;}
  .welcome-grid{grid-template-columns:1fr 1fr;}
  .cards-grid{grid-template-columns:1fr;}
  .phase-row{grid-template-columns:1fr 1fr;}
  header{padding:0.6rem 1rem;}
  .cert-badge{display:none;}
  .ref-panel,.messages{padding:1rem;}
  .input-area{padding:0.75rem 1rem 0.875rem;}
  .macro-row{grid-template-columns:repeat(3,1fr);}
}
</style>
</head>
<body>

<div id="splash">
  <div class="splash-logo">Dr. Fitness</div>
  <div class="splash-sub">Trainer Reference System — EPI · NASM · ACE · ISSA</div>
  <div class="splash-disc">
